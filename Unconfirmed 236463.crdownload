/* ── Payouts ─────────────────────────────────────────────────────────────── */
function renderPayouts(){
  const rows = DB.payouts.get();
  const host = document.getElementById('pay-table-wrap');
  if (!rows.length) { host.innerHTML = `<div class="empty" style="margin:14px">No payouts.</div>`; return; }
  host.innerHTML = `
    <table class="table">
      <thead><tr><th>Customer</th><th>DSA</th><th>Loan</th><th class="num">Amount</th><th class="num">%</th><th class="num">Gross</th><th>Status</th><th>Date</th><th class="num">Actions</th></tr></thead>
      <tbody>${rows.map(p => `
        <tr>
          <td><strong>${p.name}</strong></td><td>${p.dsaName}</td><td>${p.loanType}</td>
          <td class="num">${fmtINR(p.amount)}</td><td class="num">${p.pct}%</td>
          <td class="num"><strong>${fmtINR(Math.round(p.amount*p.pct/100))}</strong></td>
          <td>${p.paid?'<span class="badge badge-ok">Paid</span>':'<span class="badge badge-warn">Pending</span>'}</td>
          <td>${fmtDate(p.at)}</td>
          <td><div class="row-actions">
            <button class="warn" onclick="togglePaid('${p.id}')">${p.paid?'Mark pending':'Mark paid'}</button>
            <button class="danger" onclick="deletePayout('${p.id}')">Delete</button>
          </div></td>
        </tr>`).join('')}
      </tbody>
    </table>`;
}
function togglePaid(id){
  const arr = DB.payouts.get(); const i = arr.findIndex(x=>x.id===id);
  arr[i].paid = !arr[i].paid; DB.payouts.set(arr);
  DB.audit.log('edit','Payout: '+arr[i].name,'Status: '+(arr[i].paid?'Paid':'Pending'));
  refreshAll(); toast('Updated','ok');
}
function deletePayout(id){
  if (!confirm('Delete payout?')) return;
  const arr = DB.payouts.get(); const t = arr.find(x=>x.id===id);
  DB.payouts.set(arr.filter(x=>x.id!==id));
  DB.audit.log('delete','Payout: '+(t?t.name:id));
  refreshAll(); toast('Deleted','ok');
}

/* ── Reports page ─────────────────────────────────────────────────────────── */
function renderReports(){
  // DSA filter options
  const dsaSel = document.getElementById('rep-dsa-filter');
  const allUsers = DB.users.get().filter(u => ['individual-dsa','dsa-company','connector','sub-dsa'].includes(u.type));
  dsaSel.innerHTML = '<option value="">All DSAs / Partners</option>' + allUsers.map(u=>`<option value="${u.id}" ${u.id===S.repDsa?'selected':''}>${u.name}</option>`).join('');

  // KPIs
  let borr = DB.borrowers.get().filter(b => inRange(b.createdAt, S.repRange));
  if (S.repDsa) borr = borr.filter(b => b.dsaId === S.repDsa);
  const disb = borr.filter(b=>b.stage==='disb');
  const vol = disb.reduce((a,b)=>a+b.amount,0);
  document.getElementById('reports-kpi').innerHTML = [
    { l:'Range',        k: rangeLabel(S.repRange), cls:'' },
    { l:'Files in range',     k: borr.length,               cls:'info' },
    { l:'Disbursed',          k: disb.length,               cls:'success' },
    { l:'Volume',             k: fmtINR(vol),               cls:'accent' },
  ].map(x => `<div class="kpi ${x.cls}"><div class="l">${x.l}</div><div class="k" style="font-size:${x.k.length>10?'18px':'24px'}">${x.k}</div></div>`).join('');

  const reports = [
    { k:'borrowers', t:'Borrowers &amp; Files', d:'Every file with borrower, amount, stage, DSA' },
    { k:'disbursed', t:'Disbursements only',    d:'Only files with stage = Disbursed' },
    { k:'policies',  t:'Bank Policies',         d:'All saved policies (per product)' },
    { k:'dump',      t:'Files Dump profiles',   d:'Credit-review profile queue' },
    { k:'directory', t:'Banker Directory',      d:'Banker RMs, roles, contacts' },
    { k:'payouts',   t:'Payouts',               d:'Commissions with paid/pending status' },
    { k:'dsas',      t:'DSAs &amp; Companies',  d:'All DSA and DSA Company accounts' },
    { k:'partners',  t:'Connectors / Sub-DSA',  d:'Partner accounts' },
    { k:'team',      t:'Team / Accounts',       d:'Internal team users' },
    { k:'banks',     t:'Banks / NBFC',          d:'Lender desk accounts' },
    { k:'audit',     t:'Admin audit log',       d:'Every admin action' },
  ];
  document.getElementById('reports-grid').innerHTML = reports.map(r => `
    <div class="card" style="margin-bottom:0">
      <div class="card-head"><h3>${r.t}</h3></div>
      <div class="card-body">
        <div style="font-size:12px;color:var(--text-muted);margin-bottom:12px">${r.d}</div>
        <button class="btn btn-primary btn-sm" style="width:100%" onclick="exportExcel('${r.k}')">⬇ Download Excel</button>
      </div>
    </div>
  `).join('');
}

/* ── Audit ────────────────────────────────────────────────────────────────── */
function renderAudit(){
  const rows = DB.audit.get();
  const host = document.getElementById('audit-table-wrap');
  if (!rows.length) { host.innerHTML = `<div class="empty" style="margin:14px">No admin actions yet.</div>`; return; }
  host.innerHTML = `
    <table class="table">
      <thead><tr><th>When</th><th>Admin</th><th>Action</th><th>Target</th><th>Details</th></tr></thead>
      <tbody>${rows.map(l => `
        <tr>
          <td>${new Date(l.at).toLocaleString('en-IN')}</td>
          <td>+91 ${l.by}</td>
          <td><span class="badge badge-${auditBadge(l.action)}">${l.action}</span></td>
          <td>${escHtml(l.target)}</td>
          <td>${escHtml(l.details||'')}</td>
        </tr>`).join('')}
      </tbody>
    </table>`;
}
function auditBadge(a){ return ({create:'ok',edit:'info',delete:'err',hold:'warn',release:'ok'})[a] || 'muted'; }
function clearAudit(){
  if (!confirm('Clear full audit log?')) return;
  DB.audit.set([]); refreshAll(); toast('Audit log cleared','ok');
}

/* ── Excel export ─────────────────────────────────────────────────────────── */
function exportExcel(kind){
  if (typeof XLSX === 'undefined') { toast('Excel library not loaded','err'); return; }
  const { rows, name } = collectExport(kind);
  if (!rows.length) { toast('No rows to export','err'); return; }
  const ws = XLSX.utils.json_to_sheet(rows);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, name.slice(0,31));
  const dt = new Date().toISOString().slice(0,10);
  XLSX.writeFile(wb, `cancrm-admin-${name.toLowerCase().replace(/\s+/g,'-')}-${dt}.xlsx`);
  DB.audit.log('export', 'Excel: '+name, rows.length+' rows');
  toast('Exported '+rows.length+' rows','ok');
}
function collectExport(kind){
  const r = S.repRange; const dsaId = S.repDsa;
  switch(kind){
    case 'dsas': return { name:'DSAs', rows: filterUsers('dsa').map(u => ({ Name:u.name, Type:typeLabel(u.type), Mobile:u.mobile, Email:u.email||'', Status:u.status, Joined:fmtDate(u.createdAt) })) };
    case 'partners': return { name:'Partners', rows: filterUsers('partner').map(u => ({ Name:u.name, Type:typeLabel(u.type), Mobile:u.mobile, Email:u.email||'', 'Parent DSA':u.dsaName||'', Status:u.status, Joined:fmtDate(u.createdAt) })) };
    case 'team': return { name:'Team', rows: filterUsers('team').map(u => ({ Name:u.name, Type:typeLabel(u.type), Mobile:u.mobile, Email:u.email||'', 'Parent DSA':u.dsaName||'', Status:u.status, Joined:fmtDate(u.createdAt) })) };
    case 'banks': return { name:'Banks', rows: filterUsers('bank').map(u => ({ Name:u.name, Type:typeLabel(u.type), 'Bank/NBFC':u.bankName||'', Mobile:u.mobile, Email:u.email||'', Status:u.status, Joined:fmtDate(u.createdAt) })) };
    case 'borrowers': {
      let b = DB.borrowers.get().filter(x => inRange(x.createdAt, r));
      if (dsaId) b = b.filter(x => x.dsaId === dsaId);
      return { name:'Borrowers', rows: b.map(x => ({ Name:x.name, Mobile:x.mobile, Loan:x.loanType, Bank:x.bank, Amount:x.amount, Stage:x.stage, DSA:x.dsaName, Logged:fmtDate(x.createdAt), Disbursed:x.disbAt?fmtDate(x.disbAt):'' })) };
    }
    case 'disbursed': {
      let b = DB.borrowers.get().filter(x => x.stage==='disb' && inRange(x.disbAt||x.createdAt, r));
      if (dsaId) b = b.filter(x => x.dsaId === dsaId);
      return { name:'Disbursements', rows: b.map(x => ({ Name:x.name, Loan:x.loanType, Bank:x.bank, Amount:x.amount, DSA:x.dsaName, Disbursed:fmtDate(x.disbAt) })) };
    }
    case 'policies': {
      let p = DB.policies.get();
      if (S.polCat !== 'all') p = p.filter(x => x.cat === S.polCat);
      return { name:'Policies', rows: p.map(x => ({ Bank:x.bank, Product:PCATS[x.cat], ROI:x.roi, MaxAmt:x.amt, CIBIL:x.cibil, TAT:x.tat, Payout:x.pay, Geo:x.loc, Contact:x.con, Updated:fmtDate(x.updatedAt) })) };
    }
    case 'dump':      return { name:'FilesDump', rows: DB.dump.get().map(x => ({ Name:x.name, Type:x.btype, BankTO:x.tbank, GSTTO:x.tgst, ITRTO:x.titr, Req:x.req, Review:x.rdo, Created:fmtDate(x.createdAt) })) };
    case 'directory': return { name:'Directory', rows: DB.directory.get().map(x => ({ Name:x.name, Bank:x.bank, Role:x.role, City:x.city, Mobile:x.mobile, Email:x.email, Updated:fmtDate(x.updatedAt) })) };
    case 'payouts':   return { name:'Payouts', rows: DB.payouts.get().map(x => ({ Name:x.name, DSA:x.dsaName, Loan:x.loanType, Amount:x.amount, Pct:x.pct, Gross:Math.round(x.amount*x.pct/100), Status:x.paid?'Paid':'Pending', Date:fmtDate(x.at) })) };
    case 'audit':     return { name:'Audit', rows: DB.audit.get().map(x => ({ When:new Date(x.at).toLocaleString('en-IN'), Admin:x.by, Action:x.action, Target:x.target, Details:x.details })) };
    case 'top-dsas': {
      const borr = DB.borrowers.get().filter(b => inRange(b.createdAt, S.range));
      const by = {};
      borr.forEach(b => { const k = b.dsaName; by[k] = by[k] || {DSA:k,Files:0,Disbursed:0,Volume:0}; by[k].Files++; if (b.stage==='disb'){ by[k].Disbursed++; by[k].Volume += b.amount; } });
      return { name:'TopDSAs', rows: Object.values(by).sort((a,b) => b.Volume - a.Volume) };
    }
    default: return { name:'Export', rows: [] };
  }
}

/* ── Modal helpers ────────────────────────────────────────────────────────── */
function openModal(){ document.getElementById('modal').classList.add('on'); }
function closeModal(){ document.getElementById('modal').classList.remove('on'); }

/* ── Misc ─────────────────────────────────────────────────────────────────── */
function escHtml(s){ return String(s||'').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }
function escAttr(s){ return escHtml(s); }
let toastT;
function toast(msg,kind){
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast show'+(kind?' '+kind:'');
  clearTimeout(toastT); toastT = setTimeout(()=>t.className='toast',2400);
}

/* ── Dispatcher ───────────────────────────────────────────────────────────── */
function renderSection(s){
  if (s === 'overview')   renderOverview();
  if (['dsas','partners','team','banks'].includes(s)) renderAllUserTables();
  if (s === 'borrowers')  renderBorrowers();
  if (s === 'policies')   renderPolicies();
  if (s === 'dump')       renderDump();
  if (s === 'directory')  renderDirectory();
  if (s === 'payouts')    renderPayouts();
  if (s === 'reports')    renderReports();
  if (s === 'audit')      renderAudit();
}
function refreshAll(){
  updateNavBadges();
  const active = document.querySelector('.nav-item.active');
  renderSection(active ? active.dataset.section : 'overview');
}

/* ── Boot ─────────────────────────────────────────────────────────────────── */
document.addEventListener('DOMContentLoaded', () => {
  if (!checkGate()) return;
  seedIfEmpty();

  // Sidebar nav
  document.querySelectorAll('.nav-item').forEach(n => n.addEventListener('click', () => showSection(n.dataset.section)));

  // Range seg (overview)
  document.querySelectorAll('#range-seg button').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('#range-seg button').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      S.range = b.dataset.range;
      renderOverview();
    });
  });
  // Reports range seg
  document.querySelectorAll('#rep-range-seg button').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('#rep-range-seg button').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      S.repRange = b.dataset.range;
      renderReports();
    });
  });
  // Borrower stage seg
  document.querySelectorAll('#borr-stage-seg button').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('#borr-stage-seg button').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      S.borrStage = b.dataset.stage;
      renderBorrowers();
    });
  });
  // Policy cat seg
  document.querySelectorAll('#pol-cat-seg button').forEach(b => {
    b.addEventListener('click', () => {
      document.querySelectorAll('#pol-cat-seg button').forEach(x => x.classList.remove('active'));
      b.classList.add('active');
      S.polCat = b.dataset.cat;
      renderPolicies();
    });
  });

  document.getElementById('rep-dsa-filter').addEventListener('change', e => { S.repDsa = e.target.value; renderReports(); });

  document.getElementById('admin-search').addEventListener('input', e => {
    S.search = e.target.value;
    refreshAll();
  });

  // Close modal on backdrop click
  document.getElementById('modal').addEventListener('click', e => { if (e.target.id === 'modal') closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  updateNavBadges();
  renderOverview();
});
